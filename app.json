{
  "expo": {
    "name": "PANSA",
    "slug": "pansa",
    "scheme": "pansa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2F6BF6",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pansa.app"
    },
    "android": {
      "package": "com.pansa.app",
      "adaptiveIcon": {
        "backgroundColor": "#2F6BF6"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://obtnbductdphderzkftf.supabase.co",
      "supabaseAnonKey": "sb_publishable_hlJC4Ll1mcAbMmfFd4YPsg_UHE5yIdr"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "사연에 첨부할 이미지를 선택하기 위해 사진 접근 권한이 필요합니다."
        }
      ]
    ]
  }
}