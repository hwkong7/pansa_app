{
  "expo": {
    "name": "PANSA",
    "slug": "pansa",
    "scheme": "pansa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2F6BF6",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pansa.app"
    },
    "android": {
      "package": "com.pansa.app",
      "adaptiveIcon": {
        "backgroundColor": "#2F6BF6"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://khablhmfdmiqhruhcqeg.supabase.co",
      "supabaseAnonKey": "sb_publishable_IF9-e1P23-NRXCTRXf4Nhg_gj3gVaFg",
      "eas": {
        "projectId": "827eef4a-6856-4cce-b95c-1500607c4387"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "사연에 첨부할 이미지를 선택하기 위해 사진 접근 권한이 필요합니다."
        }
      ],
      "expo-web-browser"
    ],
    "owner": "iamdh0100"
  }
}

