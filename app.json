{
  "expo": {
    "name": "PANSA",
    "slug": "pansa",
    "scheme": "pansa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pansa.app"
    },
    "android": {
      "package": "com.pansa.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptiveIcon.png",
        "backgroundColor": "#2F6BF6"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://khablhmfdmiqhruhcqeg.supabase.co",
      "supabaseAnonKey": "sb_publishable_IF9-e1P23-NRXCTRXf4Nhg_gj3gVaFg",
      "naverClientId": "EN4K7XhgSwZpwrmGiqTc",
      "eas": {
        "projectId": "0762a87f-1f6c-4b3f-a689-f273e1b96226"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "사연에 첨부할 이미지를 선택하기 위해 사진 접근 권한이 필요합니다."
        }
      ],
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#2F6BF6"
        }
      ],
      "expo-font"
    ],
    "owner": "hwkong7"
  }
}
